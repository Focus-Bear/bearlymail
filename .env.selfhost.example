# ─────────────────────────────────────────────────────────────────────────────
# BearlyMail self-hosting configuration.
# Copy to `.env` (which is gitignored) and fill in the values:
#     cp .env.selfhost.example .env
# Then: docker compose -f docker-compose.selfhost.yml up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: database ───────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=adhd_email_client
# DB_HOST is set to `postgres` by the compose file — leave it unset here.

# ── Required: security ───────────────────────────────────────────────────────
# 32+ characters. Generate with:  openssl rand -hex 32
# WARNING: never change this after data is stored — you will lose access to all
# encrypted email data. Back it up somewhere safe.
ENCRYPTION_KEY=

# Generate with:  openssl rand -hex 32
JWT_SECRET=

# ── Required: at least one LLM provider ──────────────────────────────────────
# The app degrades to reduced-quality rule-based behaviour with none set, but
# priority/summaries/replies need one. Options: openai | gemini | bedrock.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ── Required to connect a Gmail account: Google OAuth ────────────────────────
# Create credentials at https://console.cloud.google.com (see SELF-HOSTING.md).
# The redirect URI must match your server's public URL + /auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ── URLs / CORS ──────────────────────────────────────────────────────────────
# Where the browser reaches the client and the API. For a real deployment put
# both behind HTTPS on one domain (client at your-domain, API at api.your-domain)
# — the client auto-targets https://api.<its-own-hostname> when VITE_API_URL is
# unset. For local Docker the defaults below are fine.
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:3001

# ── Optional: other providers / integrations ─────────────────────────────────
# MICROSOFT_CLIENT_ID=            # Office365 accounts
# MICROSOFT_CLIENT_SECRET=
# ZOHO_CLIENT_ID=                 # Zoho Mail accounts
# ZOHO_CLIENT_SECRET=
# GITHUB_APP_CLIENT_ID=           # GitHub PR/issue metadata
# GITHUB_APP_CLIENT_SECRET=

NODE_ENV=production
