{
  "name": "bearlymail-email-prioritiser",
  "version": "1.0.0",
  "description": "Lambda function for email priority analysis using SQS-triggered parallel processing",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsc && npm run copy-prompts",
    "copy-prompts": "cp ../../server/promptfoo/prompts/prioritise-email.md prompts/ && cp ../../server/promptfoo/prompts/batch-priority-triage.md prompts/",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@aws-sdk/client-cloudwatch": "^3.0.0",
    "@aws-sdk/client-kms": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "openai": "^4.77.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3"
  }
}
