# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=adhd_email_client
# Connection pool sizes — tune based on your RDS instance's max_connections.
# Both web server and worker each create a TypeORM pool (DB_POOL_SIZE) and a
# PgBoss pool (DB_PGBOSS_POOL_SIZE). Total connections ≈ (DB_POOL_SIZE + DB_PGBOSS_POOL_SIZE) × num_processes.
# DB_POOL_SIZE=10
# DB_PGBOSS_POOL_SIZE=10

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google Calendar API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Calendar Booking URL
CALENDAR_BOOKING_URL=https://calendly.com/your-link

# Frontend URL
FRONTEND_URL=http://localhost:3000

# LLM Configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
# AWS Bedrock (Amazon Nova) — powers summarisation (cheapest model). Credentials
# come from the ECS task role / AWS default chain (no API key). Region is pinned:
# the org SCP denies Bedrock in us-east-1 and Nova is enabled in the home region.
BEDROCK_REGION=ap-southeast-2
BEDROCK_MODEL=amazon.nova-micro-v1:0

# Anthropic / Claude (optional — users can supply their own sk-ant-* key via Settings)
# ANTHROPIC_API_KEY=sk-ant-...                 # system-wide fallback key
# ANTHROPIC_MODEL=claude-sonnet-4-6             # default model

# LLM Job Processing Configuration
# LLM_PRIORITY_CONCURRENCY=8       # Number of parallel priority calculation workers
# LLM_SUMMARY_PARALLEL_CALLS=5     # Number of parallel LLM calls per batch (fires concurrently, not blocking)

# Error Tracking (PostHog)
# POSTHOG_API_KEY=phc_your-api-key-here
# POSTHOG_HOST=https://us.i.posthog.com

# Global encryption key (AES-256, derived via scrypt). REQUIRED unless the
# KMS-wrapped key below is provisioned.
# ENCRYPTION_KEY=<32+ char secret>
#
# KMS-rooted global key (SAQ Q47 / ASVS V6): when KMS_KEY_ID and
# ENCRYPTION_KEY_KMS_BLOB are both set, the global key is KMS-decrypted at boot
# and no static ENCRYPTION_KEY is needed. Produce the blob with
# `ts-node -r tsconfig-paths/register src/scripts/wrap-global-key.ts`.
# KMS_KEY_ID=arn:aws:kms:ap-southeast-2:<acct>:key/<id>
# ENCRYPTION_KEY_KMS_BLOB=<base64 KMS-wrapped global key>

# Feedback Screenshots (S3)
# FEEDBACK_SCREENSHOTS_BUCKET=your-feedback-screenshots-bucket-name

# Feedback email encryption key (AES-256-GCM, 32-byte hex string — REQUIRED for feedback feature)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be set in dev, staging, and prod before deploying.
# FEEDBACK_ENCRYPTION_KEY=<32-byte-hex-string>

# Rate Limiting — feedback endpoints (POST /priority/:emailId/feedback, POST /priority/star-feedback)
# FEEDBACK_THROTTLE_TTL_MS=3600000   # 1-hour rolling window (default: 3600000)
# FEEDBACK_THROTTLE_LIMIT=10          # 10 submissions per user per hour (default: 10)

# Rate Limiting — all other API endpoints
# DEFAULT_THROTTLE_TTL_MS=60000        # 1-minute rolling window (default: 60000)
# DEFAULT_THROTTLE_LIMIT=500           # 500 requests per user per minute (default: 500 — inbox use requires many concurrent requests)

# Rate Limiting — polling/progress endpoints (e.g. GET /context/analyze-progress)
# POLLING_THROTTLE_TTL_MS=60000        # 1-minute rolling window (default: 60000)
# POLLING_THROTTLE_LIMIT=3000          # 3000 requests per user per minute (default: 3000)

# RevenueCat
# REVENUECAT_API_KEY=your-revenuecat-v2-secret-key   # sk_... with customer_information:customers:read
# REVENUECAT_PROJECT_ID=your-revenuecat-project-id   # required for v2 API reads
# REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-authorization-secret

# Two-Step Category Shortlisting (always active when category count > 12)
# CATEGORY_SHORTLIST_MODEL=gpt-5.4-nano     # Model for the shortlisting step; defaults to gpt-5.4-nano
# CATEGORY_TRIAGE_MODEL=gpt-5.4-nano         # Model for the batch triage step; defaults to gpt-5.4-nano
