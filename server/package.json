{
  "name": "adhd-email-client-server",
  "version": "1.1.0",
  "description": "Backend server for ADHD-Friendly Email Client",
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "worker:dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/worker.ts\"",
    "worker:prod": "node dist/worker",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint \"{src,apps,libs,test}/**/*.ts\" --fix --max-warnings=0",
    "test": "TZ=UTC jest",
    "test:unit": "TZ=UTC jest --testPathIgnorePatterns='.integration.spec.ts$'",
    "test:integration": "TZ=UTC jest --testRegex='.*\\.integration\\.spec\\.ts$' --runInBand",
    "test:watch": "TZ=UTC jest --watch --maxWorkers=50%",
    "test:cov": "TZ=UTC jest --coverage --testPathIgnorePatterns='.integration.spec.ts$'",
    "test:integration:cov": "TZ=UTC jest --coverage --testRegex='.*\\.integration\\.spec\\.ts$' --runInBand",
    "test:debug": "TZ=UTC node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:timing": "TZ=UTC JEST_TIMING=true jest",
    "test:detect-network": "TZ=UTC DETECT_NETWORK_CALLS=true jest",
    "test:slow": "TZ=UTC jest --verbose",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/data-source.ts",
    "migration:run:prod": "typeorm migration:run -d dist/data-source.js",
    "migration:revert:prod": "typeorm migration:revert -d dist/data-source.js",
    "migration:show:prod": "typeorm migration:show -d dist/data-source.js",
    "migration:fix": "ts-node -r tsconfig-paths/register src/scripts/fix-migration-state.ts",
    "check-indexes": "ts-node -r tsconfig-paths/register scripts/check-and-add-indexes.ts",
    "check-schema-drift": "node scripts/check-schema-drift.js",
    "check:schema": "ts-node -r tsconfig-paths/register scripts/check-schema-sync.ts",
    "analyze-queries": "ts-node -r tsconfig-paths/register scripts/analyze-slow-queries.ts",
    "jobs:reset": "ts-node -r tsconfig-paths/register src/scripts/reset-stuck-jobs.ts",
    "fix:stuck-calculating": "ts-node -r tsconfig-paths/register src/scripts/fix-stuck-calculating.ts",
    "backfill:contact-search-tokens": "ts-node -r tsconfig-paths/register src/scripts/backfill-contact-search-tokens.ts",
    "seed:test-user": "ts-node -r tsconfig-paths/register scripts/seed-test-user.ts",
    "seed:local-user": "ts-node -r tsconfig-paths/register scripts/seed-local-user.ts",
    "seed:search-data": "ts-node -r tsconfig-paths/register scripts/seed-search-data.ts",
    "seed:qa": "ts-node -r tsconfig-paths/register scripts/seed-qa-user.ts",
    "seed:qa:reset": "ts-node -r tsconfig-paths/register scripts/reset-qa-user.ts",
    "promptfoo:test": "node scripts/run-promptfoo-tests.js",
    "promptfoo:view": "promptfoo view promptfoo",
    "security:audit": "ts-node -r tsconfig-paths/register scripts/security-audit.ts",
    "security:audit:no-llm": "ts-node -r tsconfig-paths/register scripts/security-audit.ts --no-llm",
    "security:audit:diff": "ts-node -r tsconfig-paths/register scripts/security-audit.ts --diff",
    "security:audit:llm": "ts-node -r tsconfig-paths/register scripts/security-audit.ts --llm",
    "security:audit:diff:llm": "ts-node -r tsconfig-paths/register scripts/security-audit.ts --diff --llm",
    "security:audit:ci": "ts-node -r tsconfig-paths/register scripts/security-audit.ts --ci",
    "queue:dashboard": "node node_modules/@pg-boss/dashboard/bin/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1045.0",
    "@aws-sdk/client-cloudwatch": "^3.1090.0",
    "@aws-sdk/client-ecs": "^3.1090.0",
    "@aws-sdk/client-kms": "^3.1075.0",
    "@aws-sdk/client-lambda": "^3.1079.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-ses": "^3.1068.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@octokit/rest": "^22.0.1",
    "@pg-boss/dashboard": "^1.6.2",
    "@types/mjml": "^5.0.0",
    "archiver": "^7.0.1",
    "archiver-zip-encrypted": "^2.0.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "chrono-node": "^2.9.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto-js": "^4.2.0",
    "file-type": "^22.0.1",
    "form-data": "^4.0.6",
    "googleapis": "^173.0.0",
    "i18next": "^26.3.6",
    "luxon": "^3.7.2",
    "mjml": "^5.4.0",
    "natural": "^6.10.3",
    "node-ical": "^0.26.0",
    "openai": "^6.21.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.1",
    "posthog-node": "^5.38.2",
    "pusher": "^5.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jscodeshift": "^17.3.0",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.1.0",
    "@types/node": "~24",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.62.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-max-params": "^1.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jest": "^30.3.0",
    "js-yaml": "^5.2.1",
    "jscodeshift": "^17.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "promptfoo": "^0.121.19",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "isolatedModules": true,
          "tsconfig": {
            "module": "commonjs",
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 15,
        "functions": 21,
        "lines": 26,
        "statements": 27
      }
    },
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(@octokit|universal-user-agent|before-after-hook)/)"
    ],
    "moduleNameMapper": {
      "^app-root-path$": "<rootDir>/__mocks__/app-root-path.ts",
      "^mjml$": "<rootDir>/__mocks__/mjml.ts"
    },
    "setupFilesAfterEnv": [
      "../jest.setup.ts"
    ],
    "maxWorkers": "100%",
    "workerIdleMemoryLimit": "512MB",
    "cache": true,
    "cacheDirectory": "../.jest-cache",
    "verbose": false,
    "detectOpenHandles": false,
    "forceExit": true,
    "testTimeout": 10000,
    "slowTestThreshold": 1,
    "bail": false,
    "errorOnDeprecated": false
  }
}
